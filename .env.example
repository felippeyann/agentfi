# =============================================================================
# AgentFi — Environment Variables
# =============================================================================
# Copy this file to .env and fill in every required value before running.
# Variables marked "optional" can be left blank for local development.
# NEVER commit the real .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Node environment: development | staging | production
NODE_ENV=development

# Port the Fastify API listens on
API_PORT=3000

# Operator secret used to authenticate agent-registration requests (POST /v1/agents).
# Must be at least 32 characters. Generate with: openssl rand -hex 32
API_SECRET=your-api-secret-min-32-chars-here

# Port the MCP server listens on
MCP_PORT=3002


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://agentfi:agentfi@localhost:5432/agentfi


# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection string used for queues and caching.
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# RPC Providers
# -----------------------------------------------------------------------------

# Alchemy API key — used to build RPC URLs for all supported chains (required).
# Get yours at https://www.alchemy.com
ALCHEMY_API_KEY=your-alchemy-api-key-here

# Infura API key — fallback RPC provider (optional).
# Get yours at https://infura.io
INFURA_API_KEY=


# -----------------------------------------------------------------------------
# Wallet Infrastructure — Turnkey (MPC key management)
# -----------------------------------------------------------------------------
# Turnkey provisions non-custodial MPC wallets for agents.
# Private key shards never leave Turnkey infrastructure.
# Dashboard: https://app.turnkey.com

# Turnkey API public key (P-256 compressed hex)
TURNKEY_API_PUBLIC_KEY=your-turnkey-api-public-key-here

# Turnkey API private key (P-256 hex) — treat like a password, never commit
TURNKEY_API_PRIVATE_KEY=your-turnkey-api-private-key-here

# Turnkey organization ID (UUID)
TURNKEY_ORGANIZATION_ID=your-turnkey-organization-id-here


# -----------------------------------------------------------------------------
# Wallet Infrastructure — Safe (smart wallets)
# -----------------------------------------------------------------------------
# Optional. When set, each new agent gets a Safe smart wallet deployed
# automatically with the AgentPolicyModule enabled.
# If left blank, agents use their Turnkey EOA address directly (fine for
# local development and testnets).
#
# Must be a funded EOA private key that has native gas tokens on every target
# chain (ETH on mainnet/Base/Arbitrum, MATIC on Polygon).
SAFE_DEPLOYER_PRIVATE_KEY=


# -----------------------------------------------------------------------------
# Simulation — Tenderly (optional)
# -----------------------------------------------------------------------------
# Used to simulate transactions before broadcasting.
# Leave blank to skip simulation in development.
# Dashboard: https://dashboard.tenderly.co

TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=


# -----------------------------------------------------------------------------
# Stripe (billing — PRO subscriptions at $99/month)
# -----------------------------------------------------------------------------
# Create products and webhooks in the Stripe dashboard, then paste the IDs here.
# Use sk_test_* / whsec_test_* keys for local development.
# Dashboard: https://dashboard.stripe.com

# Stripe secret key (sk_live_* for production, sk_test_* for development)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# Stripe webhook signing secret — obtained from the webhook endpoint settings
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# Stripe Price ID for the PRO monthly plan (price_*)
STRIPE_PRO_PRICE_ID=price_your-stripe-pro-price-id-here


# -----------------------------------------------------------------------------
# Revenue
# -----------------------------------------------------------------------------

# Ethereum address where protocol fees are collected
OPERATOR_FEE_WALLET=0xYourEthereumAddressHere


# -----------------------------------------------------------------------------
# Admin Dashboard
# -----------------------------------------------------------------------------

# Secret header value required to access /admin/* routes (x-admin-secret).
# Must be kept private — this grants full read/write access to all agent data.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=your-admin-secret-min-32-chars-here

# NextAuth secret for the admin frontend session encryption.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-here

# Public URL of the admin frontend (used for NextAuth callbacks)
NEXTAUTH_URL=http://localhost:3001

# Admin frontend base URL
ADMIN_URL=http://localhost:3001

# CORS allowed origins (comma-separated). In production, set to your admin domain.
# Example: https://admin.agentfi.cc
# Default (when not set): https://admin.agentfi.cc
CORS_ORIGIN=https://admin.agentfi.cc

# Backend API base URL (used by the admin frontend to make API calls)
BACKEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Contracts (populated after on-chain deployment)
# -----------------------------------------------------------------------------
# Leave blank until the contracts are deployed. Each variable follows the
# pattern: <CONTRACT>_ADDRESS_<CHAIN_ID>
#
# Supported chain IDs:
#   1      — Ethereum Mainnet
#   8453   — Base
#   42161  — Arbitrum One
#   137    — Polygon

# AgentPolicyModule contract addresses
POLICY_MODULE_ADDRESS_1=
POLICY_MODULE_ADDRESS_8453=0x03afE9c56331EE6A795C873a5e7E23308F6f6A6d
POLICY_MODULE_ADDRESS_42161=
POLICY_MODULE_ADDRESS_137=

# Executor contract addresses
EXECUTOR_ADDRESS_1=
EXECUTOR_ADDRESS_8453=0x54415F0Bc61436193D2a8dD00e356eD9EBfd24b3
EXECUTOR_ADDRESS_42161=
EXECUTOR_ADDRESS_137=
