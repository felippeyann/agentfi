{
  "name": "@agentfi/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "prisma": {
    "schema": "src/db/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no eslint configured'",
    "test": "vitest run",
    "db:generate": "dotenv -e ../../.env prisma generate",
    "db:migrate": "dotenv -e ../../.env prisma migrate dev",
    "db:push": "dotenv -e ../../.env prisma db push"
  },
  "dependencies": {
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/helmet": "^11.1.1",
    "zod": "^3.22.4",
    "viem": "^2.17.0",
    "@turnkey/sdk-server": "^1.3.0",
    "@safe-global/protocol-kit": "^4.0.0",
    "@prisma/client": "^5.11.0",
    "bullmq": "^5.4.0",
    "ioredis": "^5.3.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "dotenv": "^16.4.5",
    "jose": "^5.2.4",
    "nanoid": "^5.0.7",
    "stripe": "^15.3.0",
    "fastify-plugin": "^4.5.1",
    "@aave/contract-helpers": "^1.19.0",
    "@aave/math-utils": "^1.19.0",
    "ethers": "^5.7.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "prisma": "^5.11.0",
    "vitest": "^1.4.0",
    "@types/node": "^20.11.0",
    "dotenv-cli": "^7.4.2"
  }
}
