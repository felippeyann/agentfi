{
  "name": "@agent_fi/backend",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/felippeyann/agentfi.git",
    "directory": "packages/backend"
  },
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "prisma": {
    "schema": "src/db/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no eslint configured'",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:fork": "vitest run --config vitest.config.e2e.fork.ts",
    "test:e2e:testnet": "vitest run --config vitest.config.e2e.testnet.ts",
    "db:generate": "dotenv -e ../../.env prisma generate",
    "db:migrate": "dotenv -e ../../.env prisma migrate dev",
    "db:push": "dotenv -e ../../.env prisma db push"
  },
  "dependencies": {
    "@aave/contract-helpers": "^1.19.0",
    "@aave/math-utils": "^1.19.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.11.0",
    "@safe-global/protocol-kit": "^4.0.0",
    "@turnkey/sdk-server": "^1.3.0",
    "bullmq": "^5.73.5",
    "dotenv": "^17.4.2",
    "ethers": "^5.7.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.4",
    "nanoid": "^5.0.7",
    "pino": "^8.19.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^15.3.0",
    "viem": "^2.47.14",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
