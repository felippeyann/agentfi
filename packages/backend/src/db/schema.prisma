generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id           String      @id @default(cuid())
  name         String
  apiKeyHash   String      @unique
  apiKeyPrefix String
  walletId     String      @unique
  safeAddress  String      @unique
  chainIds     Int[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  active       Boolean     @default(true)
  tier         AgentTier   @default(FREE)
  /// JSON manifest of services/tools this agent provides to other agents
  serviceManifest Json?

  // Reputation & Trust Metrics
  reputationScore Int      @default(0)
  a2aTxCount      Int      @default(0)
  lastActiveAt    DateTime @default(now())

  transactions Transaction[]
  requestedJobs Job[]      @relation("RequestedJobs")
  providedJobs  Job[]      @relation("ProvidedJobs")
  policy       AgentPolicy?
  billing      AgentBilling?

  @@index([apiKeyHash])
}

// A2A Service Request / Job Queue
model Job {
  id           String    @id @default(cuid())
  requesterId  String
  requester    Agent     @relation("RequestedJobs", fields: [requesterId], references: [id], onDelete: Cascade)
  providerId   String
  provider     Agent     @relation("ProvidedJobs", fields: [providerId], references: [id], onDelete: Cascade)
  
  status       JobStatus @default(PENDING)
  payload      Json      // The task details (e.g., { "action": "analyze", "target": "0x..." })
  reward       Json?     // Payment terms (e.g., { "amount": "0.01", "token": "ETH" })
  
  signature    String?   // Requester's signature of the payload
  result       Json?     // The output/proof of work from the provider

  // v2 Escrow — funds committed at job creation, released on terminal state
  reservedAmount    String?   // Amount in human-readable units (same as reward.amount)
  reservedToken     String?   // Token symbol or address ("ETH" or 0x...)
  reservedChainId   Int?      // Chain where funds are reserved
  reservedAt        DateTime? // Reservation timestamp
  reservationStatus String?   // "PENDING" | "RELEASED" | "CANCELLED"

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([requesterId])
  @@index([providerId])
  @@index([status])
  @@index([reservationStatus])
}

enum JobStatus {
  PENDING
  ACCEPTED
  COMPLETED
  FAILED
  CANCELLED
}

// Subscription tiers — drives rate limits and fee rates
enum AgentTier {
  FREE       // 100 tx/month, 0.3% protocol fee
  PRO        // 10,000 tx/month, 0.15% protocol fee — $99/month
  ENTERPRISE // Unlimited tx/month, 0.05% protocol fee — custom pricing
}

// Per-agent billing record (subscription + accumulated fees)
model AgentBilling {
  id                    String    @id @default(cuid())
  agentId               String    @unique
  agent                 Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  subscriptionActive    Boolean   @default(false)
  subscriptionPeriodEnd DateTime?
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  // Protocol fees collected from this agent (in USD, as string)
  totalFeesCollectedUsd String    @default("0")
  // Tx count this billing period
  txCountThisPeriod     Int       @default(0)
  periodStart           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  feeEvents FeeEvent[]
}

// Immutable log of each fee collected
model FeeEvent {
  id            String       @id @default(cuid())
  billingId     String
  billing       AgentBilling @relation(fields: [billingId], references: [id])
  transactionId String
  transaction   Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  feeUsd        String       // fee amount in USD
  feeTokens     String       // fee in native token units (wei)
  feeBps        Int          // basis points applied
  collectedAt   DateTime     @default(now())

  @@index([billingId])
  @@index([transactionId])
  @@index([collectedAt(sort: Desc)])
}

model AgentPolicy {
  id                        String    @id @default(cuid())
  agentId                   String    @unique
  agent                     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  maxValuePerTxEth          String    @default("1.0")
  maxValueForAutoApprovalEth String    @default("0.1")
  maxDailyVolumeUsd         String    @default("10000")
  allowedContracts  String[]
  allowedTokens     String[]
  cooldownSeconds   Int       @default(60)
  active            Boolean   @default(true)
  /// Optional expiry for temporary task-scoped policies (null = no expiration)
  expiresAt         DateTime?
  updatedAt         DateTime  @updatedAt
}

/// Tracks consumed x402 payment nonces to prevent replay attacks
model X402Nonce {
  id        String    @id @default(cuid())
  nonce     String    @unique
  chainId   Int
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([nonce])
  @@index([createdAt])
}

model Transaction {
  id             String    @id @default(cuid())
  idempotencyKey String?
  agentId        String
  agent          Agent     @relation(fields: [agentId], references: [id])
  chainId        Int
  txHash         String?   @unique
  status         TxStatus  @default(QUEUED)
  type           TxType
  fromToken      String?
  toToken        String?
  amountIn       String?
  amountOut      String?
  gasUsed        String?
  gasPrice       String?
  effectiveGasPriceWei String?
  error          String?
  simulation     Json?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  confirmedAt    DateTime?

  feeEvents  FeeEvent[]

  @@index([agentId, createdAt(sort: Desc)])
  @@unique([agentId, idempotencyKey])
  @@index([status])
  @@index([txHash])
}

model DailyVolume {
  id        String   @id @default(cuid())
  agentId   String
  date      String   // YYYY-MM-DD
  volumeUsd String   @default("0")
  updatedAt DateTime @updatedAt

  @@unique([agentId, date], name: "agentId_date")
  @@index([date])
}

enum TxStatus {
  PENDING
  PENDING_APPROVAL
  SIMULATING
  QUEUED
  SUBMITTED
  CONFIRMED
  FAILED
  REVERTED
}

enum TxType {
  SWAP
  TRANSFER
  DEPOSIT
  WITHDRAW
  APPROVE
  BATCH
}
